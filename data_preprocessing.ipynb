   "source": [
    "def clean_text(text):\n",
    "    \"\"\"\n",
    "    Cleans text by:\n",
    "    1. Removing emails\n",
    "    2. Removing URLs and broken web patterns\n",
    "    3. Removing extra spaces\n",
    "    \"\"\"\n",
    "\n",
    "    # Remove email IDs\n",
    "    text = re.sub(r'\\S+@\\S+', ' ', text)\n",
    "\n",
    "    # Remove standard URLs\n",
    "    text = re.sub(r'https?://\\S+|www\\.\\S+', ' ', text)\n",
    "\n",
    "    # Remove broken website patterns like:\n",
    "    # \"www countryelements co uk\"\n",
    "    text = re.sub(r'\\b(www|co|uk|com|org|net|http)\\b', ' ', text)\n",
    "\n",
    "    # Remove extra spaces/newlines/tabs\n",
    "    text = re.sub(r'\\s+', ' ', text)\n",
    "\n",
    "    # Remove leading/trailing spaces\n",
    "    text = text.strip()\n",
    "\n",
    "    return text"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "id": "169ebbc5",
   "metadata": {},
   "outputs": [],
   "source": [
    "data[\"Sentence\"] = data[\"Sentence\"].apply(clean_text)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 31,
   "id": "0fef0001",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "def expand_contractions(text):\n",
    "    expanded_text = contractions.fix(text)\n",
    "    return expanded_text"
   ]
  },
  {
